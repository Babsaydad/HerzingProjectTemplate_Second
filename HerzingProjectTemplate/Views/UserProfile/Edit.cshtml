@model HerzingProjectTemplate.Models.UserProfile

@{
    ViewData["Title"] = "Edit";
}

<div class="nutrition_create_form">
    <h1 class="form_title">Edit Profile</h1>
    <div class="d-flex justify-content-end">
        <a asp-action="Details" class="btn btn-primary" asp-route-id="@Model.UserId">Back to Profile Page</a>
    </div>

@* <h4>UserProfile</h4> *@
<hr />

    <div class="form">
        <form asp-controller="UserProfile" asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="UserId" />
            <div class="form-group">
                <label asp-for="FirstName" class="control-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastName" class="control-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Age" class="control-label"></label>
                <input asp-for="Age" class="form-control" />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Weight" class="control-label"></label>
                <input asp-for="Weight" class="form-control" />
                <span asp-validation-for="Weight" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Height" class="control-label"></label>
                <input asp-for="Height" class="form-control" />
                <span asp-validation-for="Height" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Gender" class="control-label"></label>
                <select asp-for="Gender" class="form-control">
                    <option value="">-- Select Gender --</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ActivityLevel" class="control-label"></label>
                <select asp-for="ActivityLevel" class="form-control">
                    <option value="">-- Select Activity Level --</option>
                    <option value="Sedentary">Sedentary (Office job, little exercise)</option>
                    <option value="Lightly Active">Lightly Active (1-3 days/week)</option>
                    <option value="Moderately Active">Moderately Active (3-5 days/week)</option>
                    <option value="Very Active">Very Active (6-7 days/week)</option>
                    <option value="Extra Active">Extra Active (Physical job/2x training)</option>
                </select>
                <span asp-validation-for="ActivityLevel" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FitnessGoal" class="control-label"></label>
                <select asp-for="FitnessGoal" class="form-control">
                    <option value="">-- Select Goal --</option>
                    <option value="Lose Weight">Lose Weight</option>
                    <option value="Maintain">Maintain Weight</option>
                    <option value="Gain Muscle">Gain Muscle</option>
                </select>
                <span asp-validation-for="FitnessGoal" class="text-danger"></span>
            </div>
           
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
    <br /><br /><br /><br />
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
